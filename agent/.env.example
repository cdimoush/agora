# Discord bot token — create at https://discord.com/developers/applications
AGORA_TOKEN=your-bot-token-here

# Anthropic API key — create at https://console.anthropic.com/settings/keys
# Used by Claude Code inside the container (replaces interactive login)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — create at https://platform.openai.com/api-keys
# Used for voice transcription (Vox / Whisper API)
OPENAI_API_KEY=sk-proj-your-key-here
